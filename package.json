    "bundle:scale": "esbuild src/scale/coordinator.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/scale.cjs",
    "bench:scale:image": "SCALE_IMAGE_REPO=${SCALE_IMAGE_REPO:-nscr.io/5enq753trme1k/scale}; SCALE_IMAGE_TAG=${SCALE_IMAGE_TAG:-latest}; docker buildx build --platform linux/amd64 --provenance=false --sbom=false -f src/scale/Dockerfile --push -t \"$SCALE_IMAGE_REPO:$SCALE_IMAGE_TAG\" .",
    "bench:scale:local": "tsx src/scale/coordinator.ts",
    "bench:scale:start": "tsx src/scale/scripts/start.ts",
    "bench:scale:aggregate": "tsx src/scale/scripts/aggregate.ts",
    "bench:scale:watch": "tsx src/scale/scripts/watch.ts",
    "bundle:burst-100k": "npm run bundle:scale",
    "bench:burst-100k:image": "npm run bench:scale:image",
    "bench:burst-100k:local": "npm run bench:scale:local",
    "bench:burst-100k:start": "npm run bench:scale:start",
    "bench:burst-100k:aggregate": "npm run bench:scale:aggregate",
    "bench:burst-100k:watch": "npm run bench:scale:watch",
    "update-readme": "tsx src/update-readme.ts",
    "generate-svg": "tsx src/sandbox/generate-svg.ts",
    "generate-svg:sequential": "tsx src/sandbox/generate-svg.ts --mode sequential",
    "generate-svg:staggered": "tsx src/sandbox/generate-svg.ts --mode staggered",
    "generate-svg:burst": "tsx src/sandbox/generate-svg.ts --mode burst",
    "generate-storage-svg": "tsx src/storage/generate-svg.ts",
    "generate-browser-svg": "tsx src/browser/generate-svg.ts",
    "generate-pricing-svg": "tsx src/sandbox/generate-pricing-svg.ts"
