    "bench:runloop": "tsx src/run.ts --provider runloop",
    "bench:vercel": "tsx src/run.ts --provider vercel",
    "bench:just-bash": "tsx src/run.ts --provider just-bash",
    "bench:sprites": "tsx src/run.ts --provider sprites",
